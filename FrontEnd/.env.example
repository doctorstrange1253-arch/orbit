# Orbit Frontend Environment Variables
# Copy this file to .env and fill in your values.

# Backend API URL (no trailing slash)
VITE_API_URL=http://localhost:8000/api

# Socket.IO Server URL (for real-time features like chat and video calls)
VITE_SOCKET_URL=http://localhost:8000

# --- FCM Push (native Android APK) ---
# The Android client needs google-services.json at
# FrontEnd/android/app/google-services.json. Recommended: commit it (it is the
# client build config, not a server secret; the API key is restricted by
# package name + app-signing SHA). If you'd rather not commit it, set
# GOOGLE_SERVICES_JSON here (raw JSON or base64) and the build writes the file
# automatically via scripts/write-google-services.mjs.
GOOGLE_SERVICES_JSON=
# Optional kill switch: force push OFF even on a configured build.
VITE_ENABLE_PUSH=true
