# Baked into the production web build (Vercel AND the GitHub Actions APK build).
# REST goes through the Cloudflare Worker (which fails over Railway -> Render);
# Socket.io connects DIRECTLY to Railway (the Worker can't proxy WebSocket).
VITE_API_URL=https://orbit-backend-lb.sakshamaggarwal1253.workers.dev/api
VITE_SOCKET_URL=https://orbit-production-0d45.up.railway.app
# OAuth (Google/GitHub) hits the backend DIRECTLY — the Worker can't be relied on
# to proxy the /api/auth/* redirect chain, and passport pins redirect_uri to the
# backend's own origin. Must match BACKEND_URL on Render + the redirect URIs
# registered in Google Cloud / GitHub.
VITE_OAUTH_URL=https://orbit-p563.onrender.com
